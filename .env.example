# ============================================
# HealSync Backend - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas Connection String
# Get from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/healsync?retryWrites=true&w=majority

# Alternative: Local MongoDB
# MONGO_URI=mongodb://localhost:27017/healsync

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5050
NODE_ENV=development

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate a strong secret (at least 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_to_something_secure
JWT_EXPIRE=7d

# ============================================
# EMAIL CONFIGURATION (GMAIL)
# ============================================
# For Gmail setup:
# 1. Enable 2-factor authentication
# 2. Generate App Password at: https://myaccount.google.com/apppasswords
# 3. Use the 16-character App Password below (NOT your regular Gmail password)

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here

# Alternative: Use any email service with nodemailer support
# Examples: SendGrid, Mailgun, etc.

# ============================================
# SUPABASE CONFIGURATION (Optional)
# ============================================
# Get from: https://app.supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ============================================
# MAPBOX CONFIGURATION (Optional)
# ============================================
# Get from: https://account.mapbox.com
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# URL of your frontend application
# Used for Socket.IO CORS and email links
FRONTEND_URL=http://localhost:3000

# For production:
# FRONTEND_URL=https://yourdomain.com

# ============================================
# REMINDER & SCHEDULER CONFIGURATION
# ============================================

# Cron expression for checking reminders
# Format: minute hour day month dayOfWeek
# Examples:
#   */5 * * * *     = Every 5 minutes
#   */30 * * * *    = Every 30 minutes
#   0 * * * *       = Every hour
#   0 */6 * * *     = Every 6 hours
#   0 0 * * *       = Daily at midnight
#   0 2 * * *       = Daily at 2 AM

REMINDER_CHECK_INTERVAL=*/5 * * * *

# Maximum reminders per user
MAX_REMINDERS_PER_USER=50

# Default notification advance time in minutes
NOTIFICATION_LEAD_TIME_MINUTES=15

# ============================================
# LOGGING CONFIGURATION (Optional)
# ============================================
LOG_LEVEL=info

# ============================================
# NOTES
# ============================================
# - All timestamps are in UTC
# - Keep this file secure and out of version control
# - Use strong, unique values for JWT_SECRET
# - Update NODE_ENV to "production" for production deployment
# - Test email configuration before deploying
# - Socket.IO automatically handles real-time connections

# ============================================
# TESTING CREDENTIALS
# ============================================
# For local testing, you can use:
# EMAIL_USER=test@example.com (replace with real email for sending)
# MONGO_URI=mongodb://localhost:27017/healsync (if using local MongoDB)

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# Before deploying to production:
# ☐ Change JWT_SECRET to a strong value
# ☐ Set NODE_ENV=production
# ☐ Use production MongoDB URI
# ☐ Configure production email credentials
# ☐ Set FRONTEND_URL to production domain
# ☐ Update CORS settings in app.js
# ☐ Enable SSL/TLS
# ☐ Set up monitoring and logging
# ☐ Configure database backups
# ☐ Test all notification channels
