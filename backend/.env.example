# ============================================
# HealSync Backend - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!
# All variables below are read directly by the code (kept in sync manually — see ARCHITECTURE.md).

# ============================================
# DATABASE
# ============================================
# MongoDB Atlas Connection String — get from https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/healsync?retryWrites=true&w=majority
# Alternative: local MongoDB
# MONGO_URI=mongodb://localhost:27017/healsync

# ============================================
# SERVER
# ============================================
PORT=5050
NODE_ENV=development

# ============================================
# JWT
# ============================================
# Generate a strong secret (at least 32 characters), e.g. `openssl rand -base64 32`
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_to_something_secure
JWT_EXPIRE=7d

# ============================================
# PASSWORD HASHING
# ============================================
# bcrypt salt rounds (10 is a good default; higher = slower/more secure)
SALTROUNDS=10

# ============================================
# MEDICAL DATA ENCRYPTION (required)
# ============================================
# AES-256-GCM key for encrypting OCR text, form entries, biometric tokens, etc.
# Generate with: node generateEncryptionKey.js
# CRITICAL: losing/changing this key makes all previously-encrypted data permanently unreadable.
ENCRYPTION_KEY=

# ============================================
# EMAIL (Resend — https://resend.com)
# ============================================
# Sends over HTTPS, not SMTP — several hosts (Render included) block outbound SMTP entirely as
# an anti-spam measure, which raw Gmail/nodemailer SMTP hits directly. Sign up at resend.com,
# create an API key, and (once you verify a sending domain there) set RESEND_FROM to an address
# on it. Until a domain is verified, Resend's shared sandbox address only delivers to the email
# you signed up to Resend with — fine for testing, not for real users.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=HealSync <onboarding@resend.dev>

# ============================================
# SUPABASE STORAGE (medical document uploads)
# ============================================
# Get from https://app.supabase.com — use the service role key (server-side writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ============================================
# MAPBOX (pharmacy geocoding)
# ============================================
# Get from https://account.mapbox.com
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# ============================================
# TWILIO (WhatsApp OTP for doctor-access requests)
# ============================================
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH=your_twilio_auth_token
# Just the phone number — otpService.js adds the "whatsapp:" prefix itself.
WHATSAPP_FROM=+14155238886

# ============================================
# OCR.SPACE (prescription/document OCR)
# ============================================
# Use apipro1.ocr.space instead if you have a paid PRO plan key.
OCR_API_KEY=your_ocr_space_api_key
OCR_URL=https://api.ocr.space/parse/image

# ============================================
# GROQ (AI Assistant — RAG chat, document classification/summary)
# ============================================
# Get a key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================
# FRONTEND / BACKEND ORIGINS
# ============================================
# Used for Socket.IO CORS, main API CORS, and links generated in emails/QR codes/reset pages.
FRONTEND_URL=http://localhost:5173
BACKEND_ORIGIN=http://localhost:5050

# ============================================
# REMINDER SCHEDULER
# ============================================
# Cron expression for how often due reminders are checked (default: every 5 minutes)
REMINDER_CHECK_INTERVAL=*/5 * * * *

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# Before deploying to production:
# [ ] Change JWT_SECRET to a strong, unique value
# [ ] Set NODE_ENV=production
# [ ] Use a production MongoDB URI
# [ ] Generate and store ENCRYPTION_KEY securely (e.g. a secrets manager) — never rotate without a migration plan
# [ ] Set up a Resend account and verify a sending domain for production email delivery
# [ ] Set FRONTEND_URL and BACKEND_ORIGIN to production domains
# [ ] Provide Supabase / Mapbox / Twilio / OCR.space credentials for those features to work
# [ ] Provide a production GROQ_API_KEY for AI chat/summary features
