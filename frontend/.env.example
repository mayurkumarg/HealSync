# HealSync Frontend — environment configuration
# Copy to .env.local to override. All values are optional in local dev.

# Base URL for the backend API.
# Leave unset to use the relative "/api" path, which the Vite dev server proxies
# to http://localhost:5050 (see vite.config.ts). Set this only for a remote API.
# VITE_API_URL=https://api.your-domain.com/api
